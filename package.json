{
  "name": "ledger",
  "version": "1.0.2",
  "description": "Ledger — local-first forex trading journal for Windows",
  "author": "ikebude",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ikebude/FX-Trading-Journal.git"
  },
  "bugs": {
    "url": "https://github.com/ikebude/FX-Trading-Journal/issues"
  },
  "homepage": "https://github.com/ikebude/FX-Trading-Journal#readme",
  "main": "dist-electron/main.cjs",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "package": "node scripts/gen-icons.js && electron-vite build && electron-builder",
    "package:win": "node scripts/gen-icons.js && electron-vite build && electron-builder --win",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-checkbox": "^1.1.4",
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-dropdown-menu": "^2.1.6",
    "@radix-ui/react-label": "^2.1.2",
    "@radix-ui/react-popover": "^1.1.6",
    "@radix-ui/react-select": "^2.1.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.1.2",
    "@radix-ui/react-tabs": "^1.1.3",
    "@radix-ui/react-toast": "^1.2.6",
    "@radix-ui/react-tooltip": "^1.1.8",
    "@tanstack/react-query": "^5.66.0",
    "@tanstack/react-router": "^1.95.0",
    "@tanstack/react-table": "^8.21.0",
    "@tanstack/react-virtual": "^3.11.0",
    "better-sqlite3": "^12.8.0",
    "cheerio": "^1.0.0",
    "chokidar": "^4.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.0.4",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "drizzle-orm": "^0.39.0",
    "electron-log": "^5.3.0",
    "electron-updater": "^6.3.9",
    "lucide-react": "^0.475.0",
    "nanoid": "^5.0.9",
    "papaparse": "^5.4.1",
    "pdfkit": "^0.16.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.72.1",
    "react-markdown": "^9.0.3",
    "recharts": "^2.15.0",
    "remark-gfm": "^4.0.0",
    "sharp": "^0.33.5",
    "tailwind-merge": "^2.6.0",
    "zod": "^3.24.1",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.7",
    "@types/papaparse": "^5.3.15",
    "@types/pdfkit": "^0.13.9",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "drizzle-kit": "^0.30.2",
    "electron": "^34.0.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^3.0.0",
    "eslint": "^9.18.0",
    "postcss": "^8.5.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.58.1",
    "vite": "^6.0.7",
    "vitest": "^3.0.2"
  },
  "build": {
    "appId": "com.ledger.journal",
    "productName": "Ledger",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist-electron/**/*",
      "dist/**/*"
    ],
    "extraResources": [
      {
        "from": "electron/mql",
        "to": "mql"
      },
      {
        "from": "schema.sql",
        "to": "schema.sql"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico",
      "signingHashAlgorithms": null,
      "sign": null,
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Ledger"
    },
    "publish": {
      "provider": "github",
      "owner": "ikebude",
      "repo": "FX-Trading-Journal",
      "releaseType": "release"
    }
  }
}
